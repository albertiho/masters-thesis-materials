# Standalone thesis training repository - environment configuration
# Copy this file to .env and adjust values as needed.
#
# The .env file is gitignored and should NEVER be committed.

# =============================================================================
# ENVIRONMENT (Required)
# =============================================================================
# Default: dev
ENVIRONMENT=dev

# =============================================================================
# Anomaly Detection Configuration
# =============================================================================
# Price persistence tolerance (percentage as decimal)
# If set, prices within this % of each other are considered "the same"
# for persistence acceptance. E.g., 0.03 = 3% tolerance means:
#   - $100 → $100: Accepted (exact match)
#   - $100 → $98:  Accepted (2% diff < 3% threshold)
#   - $100 → $95:  Resets clock (5% diff > 3% threshold)
# Default: 0.02 (2% tolerance)
# PRICE_PERSIST_THRESHOLD=0.03

